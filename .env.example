# Required: Target URL to scan.
TARGET1=https://example.com

# Required: Path to the wordlist inside the container.
WORDLIST=/wordlists/common.txt

# Required: Discord webhook URL for change notifications.
DISCORD_WEBHOOK=https://discord.com/api/webhooks/REPLACE_ME

# Optional: Path to persisted JSONL scan state baseline.
# Default: /data/state.jsonl
STATE_FILE=/data/state.jsonl

# Optional: Delay between scans (Go duration format like 30m, 1h, 2h).
# Default: 1h
SCAN_INTERVAL=1h

# Optional: Number of concurrent workers.
# Default: 50
WORKERS=50

# Optional: Comma-separated HTTP status codes to match.
# Default: 200,301,302,403
MATCH_CODES=200,301,302,403

# Optional: semicolon-separated HTTP headers for WAF/Cloudflare bypass.
# Format: "HeaderName:value;AnotherHeader:value"
# HEADERS=User-Agent:Mozilla/5.0 (Windows NT 10.0; Win64; x64);Cookie:cf_clearance=YOUR_VALUE

# Optional: comma-separated extensions to append to each wordlist word.
# Useful for finding files like /admin.php, /config.js, /index.html
# Format: "php,html,js,txt" (leading dot optional)
# Default: empty (directory fuzzing only, no extension appending)
# EXTENSIONS=php,html,txt,js

# Optional: HTTP method to use for all requests to this target.
# Allowed: GET, POST, HEAD, PUT, DELETE, OPTIONS, PATCH
# Default: empty (uses engine default)
# METHOD=HEAD

# Optional: Log verbosity level.
# Allowed: info, debug
# Default: info
LOG_LEVEL=info
